# Example .env file for ktalk-ai
# Copy to a file named `.env` and set appropriate values. Do NOT commit your real keys.

# OpenAI (optional). If set, app will use OpenAI by default.
# Leave empty if you only want to use a local Ollama backend.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano
# OpenAI image generation
DALLE_MODEL=gpt-image-1.5

# Google Gemini API Key (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
# Gemini image model (optional)
GEMINI_IMAGE_MODEL=gemini-2.5-flash-img

# Backend selection: 'openai', 'ollama', or 'gemini'.
# - To use your local Ollama `exaone` model, set MODEL_BACKEND=ollama
# - To use OpenAI's hosted API, set MODEL_BACKEND=openai
# - To use Google Gemini API, set MODEL_BACKEND=gemini
MODEL_BACKEND=gemini

# Ollama settings (only used when MODEL_BACKEND=ollama)
# Default assumes Ollama local server at port 11434 and model named `exaone`.
OLLAMA_URL=http://localhost:11434
# Recommended default: pick an exaone model available on your Ollama server.
# You can leave this blank to allow the app to auto-select a preferred exaone model at startup.
OLLAMA_MODEL=exaone3.5:7.8b

# STT/TTS backend
STT_BACKEND=local
LOCAL_STT=vosk
VOSK_MODEL_PATH=/home/scottk/.local/vosk-models/vosk-model-small-ko-0.22
# Temp directory for audio conversion and other scratch files.
# If your root filesystem is read-only, set this to a writable path under /home.
ONUI_TMP_DIR=/home/scottk/Projects/onui-ai/data/tmp
TTS_BACKEND=gemini
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_FORMAT=wav
# Gemini TTS (requires GEMINI_API_KEY)
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_MIME=audio/wav
TTS_PREWARM_ON_STARTUP=0

# Korean Basic Dictionary (krdict) API
KRDICT_API_KEY=
# Optional override (default: https://krdict.korean.go.kr/api/search)
KRDICT_API_URL=

# ngrok (optional, for public access)
# If you have a paid ngrok account, set your authtoken and a reserved domain.
# - NGROK_AUTHTOKEN: from https://dashboard.ngrok.com/get-started/your-authtoken
# - NGROK_DOMAIN: your reserved domain (e.g., your-app.ngrok.app or ngrok-free.dev)
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# Microsoft Clarity Project ID
CLARITY_PROJECT_ID=
