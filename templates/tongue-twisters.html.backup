  <script>
    // Lightweight Markdown + sanitizer 로더
    (function loadMarkdownLibs() {
      const libs = [
        "https://cdn.jsdelivr.net/npm/marked/marked.min.js",
        "https://cdn.jsdelivr.net/npm/dompurify@2.4.0/dist/purify.min.js",
      ];
      libs.forEach((src) => {
        const s = document.createElement("script");
        s.src = src;
        s.defer = true; // 렌더 순서 보장에 도움
        document.head.appendChild(s);
      });
    })();

    // Markdown 안전 렌더러 (마크다운을 HTML로 변환 후 sanitize)
    function renderMarkdownSafe(targetEl, text) {
      if (!targetEl) return;
      const safeText = typeof text === "string" ? text : "";

      // 1) marked + DOMPurify가 준비된 경우
      if (window.marked && window.DOMPurify) {
        try {
          let html = DOMPurify.sanitize(marked.parse(safeText));
          // li 항목들 사이에 margin 추가
          html = html.replace(/<li>/g, '<li style="margin-bottom: 0.75rem;">');
          // 단락 사이에 더 큰 여백 추가
          html = html.replace(/<p>/g, '<p style="margin-bottom: 0.75rem;">');
          targetEl.innerHTML = html;
          return;
        } catch (e) {
          // fall through
        }
      }

      // 2) 최소 폴백 렌더링 (간단한 마크다운만)
      const escapeHtml = (s) =>
        s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");

      let html = escapeHtml(safeText);

      // **bold** -> <strong>
      html = html.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>");
      // *italic* or _italic_ -> <em>
      html = html.replace(/\*(.+?)\*/g, "<em>$1</em>");
      html = html.replace(/_(.+?)_/g, "<em>$1</em>");
      // 줄바꿈 -> <br> (그 사이에 여백 추가)
      html = html
        .split("\n")
        .map((line) => {
          if (line.trim()) {
            return `<div style="margin-bottom: 0.75rem;">${line}</div>`;
          }
          return "";
        })
        .join("");

      targetEl.innerHTML = html;
    }

    // AI 피드백을 꾸며주는 헬퍼 (마크다운 기호 제거 + 보기 좋게 정리)
    function formatAiFeedback(raw, score) {
      const txt = (raw || "").trim();
      if (!txt) return "";

      // 1) 코드블록 제거 (혹시라도 들어오면)
      let cleaned = txt.replace(/```[\s\S]*?```/g, "").trim();

      // 2) 마크다운 흔적 제거/치환
      cleaned = cleaned
        .replace(/^#{1,6}\s*/gm, "") // headings
        .replace(/\*\*(.+?)\*\*/g, "$1") // bold
        .replace(/^>\s*/gm, "") // blockquote
        .replace(/^\s*([-*+])\s+/gm, "• ") // unordered list -> •
        .replace(/^\s*\d+\.\s+/gm, "• "); // ordered list -> •

      // 3) 섹션 헤더는 이모지 없이 유지
      const ensureHeaderEmoji = (line) => {
        // 이모지 추가 안함 - 프롬프트에서 받은 그대로 사용
        return line;
      };

      const lines = cleaned
        .split("\n")
        .map((l) => l.trim())
        .filter(Boolean)
        .map(ensureHeaderEmoji);

      const output = lines.join("\n").trim();
      if (!output) return "";

      // 단일 문장만 올 때는 앞에 반짝이 표시만 붙여서 보기 좋게
      const hasLineBreak = output.includes("\n");
      if (!hasLineBreak) {
        const hasEmoji = /[\u{1F300}-\u{1FAFF}\u{2600}-\u{27BF}]/u.test(output);
        return hasEmoji ? output : `✨ ${output}`;
      }

      return output;
    }

    function extractFeedbackSections(text) {
      if (!text) return null;
      const lines = text
        .split("\n")
        .map((line) => line.trim())
        .filter(Boolean);

      if (!lines.length) return null;

      const sections = {
        summary: [],
        strengths: [],
        improvements: [],
        tips: [],
        general: [],
      };

      let currentSection = null;

      const stripEmoji = (line) =>
        line.replace(/^[\u{1F300}-\u{1FAFF}\u{2600}-\u{27BF}]+\s*/u, "").trim();
      const baseCleaner = (line) =>
        stripEmoji(line.replace(/^[•\u2022\-*+>\d.\s]+/, "")).trim();

      const isHeaderLine = (line) => {
        const stripped = stripEmoji(line);
        if (!stripped) return null;
        if (/한줄\s*요약/i.test(stripped)) return "summary";
        if (/(잘한\s*점|강점)/i.test(stripped)) return "strengths";
        if (/(개선|보완|교정)/i.test(stripped)) return "improvements";
        if (/(연습|방법|팁|추천)/i.test(stripped)) return "tips";
        if (/(점수\s*요약|스코어|점수)/i.test(stripped)) return "summary";
        return null;
      };

      const strengthKeywords = [
        "강점",
        "잘",
        "좋",
        "탁월",
        "완벽",
        "우수",
        "높은",
        "안정",
      ];
      const improvementKeywords = [
        "개선",
        "보완",
        "부족",
        "주의",
        "문제",
        "어려움",
        "교정",
        "낮은",
      ];
      const tipKeywords = [
        "팁",
        "추천",
        "연습",
        "시도",
        "방법",
        "tip",
        "도움",
      ];

      lines.forEach((line) => {
        // 섹션 헤더(예: "✅ 잘한 점")는 저장하지 않고 현재 섹션만 전환
        const headerSection = isHeaderLine(line);
        if (headerSection) {
          currentSection = headerSection;
          // "📌 한줄 요약: ..." 형태면 콜론 뒤 내용을 summary로 바로 저장
          const inlineSummary = stripEmoji(line).split(":").slice(1).join(":").trim();
          if (headerSection === "summary" && inlineSummary) {
            sections.summary.push(inlineSummary);
          }
          return;
        }

        const cleaned = baseCleaner(line);
        if (!cleaned) return;
        const normalized = cleaned.toLowerCase();

        if (currentSection) {
          sections[currentSection].push(cleaned);
          return;
        }

        if (
          strengthKeywords.some(
            (kw) => cleaned.includes(kw) || normalized.includes(kw)
          )
        ) {
          sections.strengths.push(cleaned);
        } else if (
          improvementKeywords.some(
            (kw) => cleaned.includes(kw) || normalized.includes(kw)
          )
        ) {
          sections.improvements.push(cleaned);
        } else if (
          tipKeywords.some(
            (kw) => cleaned.includes(kw) || normalized.includes(kw)
          )
        ) {
          sections.tips.push(cleaned);
        } else {
          sections.general.push(cleaned);
        }
      });

      const hasContent = Object.values(sections).some(
        (arr) => Array.isArray(arr) && arr.length > 0
      );

      return hasContent ? sections : null;
    }

    function buildFeedbackSectionMarkup(sections) {
      if (!sections) return "";
      const parts = [];

      if (sections.summary.length) {
        parts.push(`
          <div class="mb-4 rounded-xl bg-blue-50/80 border border-blue-200 p-4 text-sm text-blue-800">
            <div class="font-semibold text-blue-900 mb-1 flex items-center gap-2">
              <span>📌</span>핵심 요약
            </div>
            <p>${sections.summary.join("<br>")}</p>
          </div>
        `);
      }

      const sectionOrder = [
        {
          key: "strengths",
          title: "강점 포인트",
          icon: "💪",
          border: "border-green-200",
          bg: "bg-green-50/60",
        },
        {
          key: "improvements",
          title: "개선이 필요한 부분",
          icon: "🛠️",
          border: "border-orange-200",
          bg: "bg-orange-50/60",
        },
        {
          key: "tips",
          title: "연습 팁",
          icon: "💡",
          border: "border-sky-200",
          bg: "bg-sky-50/60",
        },
        {
          key: "general",
          title: "추가 코멘트",
          icon: "📝",
          border: "border-slate-200",
          bg: "bg-slate-50/60",
        },
      ];

      sectionOrder.forEach((section, idx) => {
        const items = sections[section.key];
        if (!items || !items.length) return;

        if (parts.length) {
          parts.push('<div class="border-t border-blue-100 my-4"></div>');
        }

        const listItems = items
          .map(
            (item) =>
              `<li class="flex items-start gap-3 text-gray-800">
                <span class="text-base leading-6 text-gray-500">•</span>
                <span>${item}</span>
              </li>`
          )
          .join("");

        parts.push(`
          <section class="rounded-xl ${section.bg} border ${section.border} p-4 shadow-sm">
            <header class="flex items-center gap-2 text-sm font-semibold text-gray-800 mb-3">
              <span>${section.icon}</span>
              <span>${section.title}</span>
            </header>
            <ul class="space-y-2">${listItems}</ul>
          </section>
        `);
      });

      return parts.join("\n");
    }

    // 전역 상태 관리 객체
    const appState = {
      mediaRecorder: null,
      recordedChunks: [],
      recordingStartTime: null,
      recordingTimer: null,
      selectedSentence: null,
      selectedSentenceIndex: -1,
      aiFeedbackSteps: [],
      aiFeedbackStepIndex: 0,
      latestAiFeedbackText: "",
      latestAiFeedbackScore: 0,
      currentBlobUrl: null,
      evaluationTimeoutId: null,
      
      // 상태 초기화 메서드
      reset() {
        if (this.currentBlobUrl) {
          URL.revokeObjectURL(this.currentBlobUrl);
        }
        if (this.evaluationTimeoutId) {
          clearTimeout(this.evaluationTimeoutId);
        }
        this.mediaRecorder = null;
        this.recordedChunks = [];
        this.recordingStartTime = null;
        this.recordingTimer = null;
        this.currentBlobUrl = null;
        this.evaluationTimeoutId = null;
      }
    };

    // 녹음 시작
    async function startRecording() {
      try {
        // 마이크 접근 권한 요청
        const stream = await navigator.mediaDevices.getUserMedia({
          audio: true,
        });

        // UI 업데이트 - 버튼 숨김
        document.getElementById("start-recording").classList.add("hidden");

        // 카운트다운 표시
        const countdownDisplay = document.getElementById("countdown-display");
        countdownDisplay.classList.remove("hidden");

        let countdown = 3;
        countdownDisplay.textContent = countdown;

        const countdownInterval = setInterval(() => {
          countdown--;

          if (countdown > 0) {
            countdownDisplay.textContent = countdown;
          } else {
            clearInterval(countdownInterval);
            countdownDisplay.classList.add("hidden");

            // 실제 녹음 시작
            appState.mediaRecorder = new MediaRecorder(stream);
            appState.recordedChunks = [];
            appState.recordingStartTime = Date.now();

            appState.mediaRecorder.ondataavailable = (event) => {
              appState.recordedChunks.push(event.data);
            };

            appState.mediaRecorder.onstop = () => {
              // 기존 Blob URL이 있으면 해제
              if (appState.currentBlobUrl) {
                URL.revokeObjectURL(appState.currentBlobUrl);
                appState.currentBlobUrl = null;
              }
              
              const audioBlob = new Blob(appState.recordedChunks, { type: "audio/wav" });
              appState.currentBlobUrl = URL.createObjectURL(audioBlob);
              // 재생 UI는 숨김 유지하지만 평가용으로 src만 설정
              document.getElementById("audio-playback").src = appState.currentBlobUrl;
              document.getElementById("evaluate-button").disabled = false;
            };

            appState.mediaRecorder.start();

            // UI 업데이트
            document.getElementById("stop-recording").classList.remove("hidden");
            
            // Visualizer 업데이트
            const visualizer = document.getElementById("recording-visualizer");
            visualizer.setAttribute("data-status", "recording");
            document.getElementById("status-text").textContent = t("speechpro.status_recording", "녹음 중");
            
            // 타이머 시작
            startTimer();

            showMessage(t("speechpro.msg.record_start", "녹음이 시작되었습니다"), "info");
          }
        }, 1000);
      } catch (error) {
        // 카운트다운 표시 숨김
        document.getElementById("countdown-display").classList.add("hidden");
        // 버튼 표시
        document.getElementById("start-recording").classList.remove("hidden");
        showError(
          `${t("speechpro.msg.mic_fail_prefix", "마이크 접근 실패: ")}${error.message}`
        );
      }
    }

    // 녹음 중지
    function stopRecording() {
      if (appState.mediaRecorder && appState.mediaRecorder.state !== "inactive") {
        appState.mediaRecorder.stop();
        appState.mediaRecorder.stream.getTracks().forEach((track) => track.stop());

        // UI 업데이트
        document.getElementById("start-recording").classList.remove("hidden");
        document.getElementById("stop-recording").classList.add("hidden");
        
        // Visualizer 업데이트
        const visualizer = document.getElementById("recording-visualizer");
        visualizer.setAttribute("data-status", "recorded");
        document.getElementById("status-text").textContent = t("speechpro.status_complete", "녹음 완료");
        
        // Progress 업데이트
        updateProgressStep(3);

        // 타이머 중지
        stopTimer();

        // 평가 버튼 활성화 및 자동 평가 시작
        if (appState.recordedChunks && appState.recordedChunks.length > 0) {
          document.getElementById("evaluate-button").disabled = false;
          
          // 즉시 평가 시작
          evaluatePronunciation();
        }

        showMessage(t("speechpro.msg.record_done", "녹음이 완료되었습니다"), "success");
      }
    }

    // 녹음 초기화
    function clearRecording() {
      // Blob URL 해제
      if (appState.currentBlobUrl) {
        URL.revokeObjectURL(appState.currentBlobUrl);
        appState.currentBlobUrl = null;
      }
      
      appState.mediaRecorder = null;
      appState.recordedChunks = [];
      appState.recordingStartTime = null;

      document.getElementById("audio-playback").src = "";
      document.getElementById("playback-section").classList.add("hidden");
      
      // Visualizer 초기화
      const visualizer = document.getElementById("recording-visualizer");
      visualizer.setAttribute("data-status", "idle");
      document.getElementById("status-text").textContent = t("speechpro.status_idle", "대기 중");
      document.getElementById("waveform").classList.add("hidden");
      document.getElementById("recording-timer-display").textContent = "00:00";
      
      document.getElementById("start-recording").classList.remove("hidden");
      document.getElementById("stop-recording").classList.add("hidden");
      document.getElementById("evaluate-button").disabled = true;

      hideError();
    }

    // 녹음된 음성 재생/정지 (토글)
    function playRecording() {
      const audioPlayback = document.getElementById("audio-playback");
      const playButton = document.getElementById("play-recording");

      if (audioPlayback.src) {
        if (audioPlayback.paused) {
          // 재생 시작
          audioPlayback.play();
          playButton.innerHTML = `⏸️ ${t("speechpro.btn_pause", "정지")}`;
          playButton.classList.remove("bg-green-500", "hover:bg-green-600");
          playButton.classList.add("bg-yellow-500", "hover:bg-yellow-600");
        } else {
          // 재생 중지
          audioPlayback.pause();
          playButton.innerHTML = `▶️ ${t("speechpro.btn_play_label", "재생")}`;
          playButton.classList.remove("bg-yellow-500", "hover:bg-yellow-600");
          playButton.classList.add("bg-green-500", "hover:bg-green-600");
        }
      }
    }

    // ========== Event Listener Setup ==========
    function setupEventListeners() {
      // Recording controls
      document.getElementById('start-recording').addEventListener('click', startRecording);
      document.getElementById('stop-recording').addEventListener('click', stopRecording);
      
      // Evaluation
      document.getElementById('evaluate-button').addEventListener('click', evaluatePronunciation);
      document.getElementById('listen-sentence-btn').addEventListener('click', playSelectedSentenceTTS);
      document.getElementById('next-sentence-btn').addEventListener('click', nextSentence);
      
      // Modal controls
      document.getElementById('close-results-btn').addEventListener('click', closeResults);
      document.getElementById('close-ai-feedback-modal-btn').addEventListener('click', closeAiFeedbackModal);
      document.getElementById('close-results-btn-2').addEventListener('click', closeResults);
      document.getElementById('reset-evaluation-btn').addEventListener('click', resetEvaluation);
      
      // Result tabs
      document.getElementById('tab-score').addEventListener('click', () => switchResultTab('score'));
      document.getElementById('tab-analysis').addEventListener('click', () => switchResultTab('analysis'));
      document.getElementById('tab-ai').addEventListener('click', () => switchResultTab('ai'));
      document.getElementById('view-details-btn').addEventListener('click', () => switchResultTab('analysis'));
      
      // AI feedback navigation
      document.getElementById('ai-feedback-prev').addEventListener('click', prevAiFeedbackStep);
      document.getElementById('ai-feedback-next').addEventListener('click', nextAiFeedbackStep);
      // Removed: ai-feedback-button (now integrated into tabs)
      
      // Character popup
      document.getElementById('close-character-popup').addEventListener('click', closeCharacterPopup);
      document.getElementById('character-popup-modal').addEventListener('click', function(e) {
        if (e.target.id === 'character-popup-modal') {
          closeCharacterPopup(e);
        }
      });
    }
    
    // Result tab switching
    function switchResultTab(tabName) {
      // Update tab buttons
      const tabs = document.querySelectorAll('.result-tab');
      tabs.forEach(tab => {
        if (tab.dataset.tab === tabName) {
          tab.classList.add('border-orange-500', 'text-orange-600');
          tab.classList.remove('border-transparent', 'text-gray-500');
        } else {
          tab.classList.remove('border-orange-500', 'text-orange-600');
          tab.classList.add('border-transparent', 'text-gray-500');
        }
      });
      
      // Update content visibility
      document.getElementById('result-content-score').classList.toggle('hidden', tabName !== 'score');
      document.getElementById('result-content-analysis').classList.toggle('hidden', tabName !== 'analysis');
      document.getElementById('result-content-ai').classList.toggle('hidden', tabName !== 'ai');
    }

    // 재생 완료 시 버튼 복원
    document.addEventListener("DOMContentLoaded", function () {
      setupEventListeners();
      
      const audioPlayback = document.getElementById("audio-playback");
      // Audio playback uses native controls, no custom button handling needed
    });

    // 타이머 관련
    function startTimer() {
      appState.recordingTimer = setInterval(() => {
        const elapsed = Math.floor((Date.now() - appState.recordingStartTime) / 1000);
        const minutes = Math.floor(elapsed / 60);
        const seconds = elapsed % 60;
        const timeStr = `${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
        
        // 두 타이머 모두 업데이트
        document.getElementById("recording-timer").textContent = timeStr;
        document.getElementById("recording-timer-display").textContent = timeStr;
      }, 100);
    }

    function stopTimer() {
      if (appState.recordingTimer) {
        clearInterval(appState.recordingTimer);
      }
    }

    // 발음 평가 실행
    async function evaluatePronunciation() {
      let text = "";

      // appState.selectedSentence에서 문장 가져오기
      if (appState.selectedSentence) {
        text = appState.selectedSentence.sentenceKr || appState.selectedSentence.korean || "";
      }

      if (!text) {
        showError(t("speechpro.msg.select_sentence", "평가할 문장을 선택해주세요"));
        return;
      }

      const audioElement = document.getElementById("audio-playback");

      if (!audioElement.src) {
        // 토스트 메시지로 표시 (오른쪽 하단)
        ToastManager.info(
          t("speechpro.msg.no_recording", "녹음된 파일이 없습니다. 먼저 음성을 녹음해주세요."),
          3000
        );
        return;
      }

      // 로딩 표시
      showLoading(t("speechpro.msg.loading_eval", "발음 정확도 분석 중입니다..."));
      hideError();

      // 기존 타임아웃이 있으면 취소
      if (appState.evaluationTimeoutId) {
        clearTimeout(appState.evaluationTimeoutId);
        appState.evaluationTimeoutId = null;
      }

      const controller = new AbortController();
      const timeoutMs = 25000;
      appState.evaluationTimeoutId = setTimeout(() => controller.abort(), timeoutMs);

      try {
        const aiButton = document.getElementById("ai-feedback-button");
        if (aiButton) aiButton.disabled = true;
        // 오디오 데이터 수집
        const audio = new Audio(audioElement.src);
        const audioBlob = await fetch(audioElement.src).then((r) => r.blob());

        // FormData 생성
        const formData = new FormData();
        formData.append("text", text);
        formData.append("audio", audioBlob, "recording.wav");

        formData.append("include_ai", "true");

        // 프리셋 문장인 경우 사전 계산 정보 전송
        console.log("[evaluatePronunciation] Checking metadata:");
        console.log("  - appState.selectedSentence:", appState.selectedSentence);
        console.log("  - syll_ltrs type:", typeof appState.selectedSentence?.syll_ltrs);
        console.log("  - syll_ltrs value:", appState.selectedSentence?.syll_ltrs);
        console.log("  - syll_phns type:", typeof appState.selectedSentence?.syll_phns);
        console.log("  - syll_phns value:", appState.selectedSentence?.syll_phns);
        console.log("  - fst type:", typeof appState.selectedSentence?.fst);
        console.log("  - fst length:", appState.selectedSentence?.fst?.length);
        
        if (
          appState.selectedSentence &&
          appState.selectedSentence.syll_ltrs &&
          appState.selectedSentence.syll_phns &&
          appState.selectedSentence.fst
        ) {
          try {
            const syll_ltrs = String(appState.selectedSentence.syll_ltrs || "");
            const syll_phns = String(appState.selectedSentence.syll_phns || "");
            const fst = String(appState.selectedSentence.fst || "");
            
            console.log("[evaluatePronunciation] After String conversion:");
            console.log("  - syll_ltrs length:", syll_ltrs.length);
            console.log("  - syll_phns length:", syll_phns.length);
            console.log("  - fst length:", fst.length);
            
            if (syll_ltrs && syll_phns && fst) {
              formData.append("syll_ltrs", syll_ltrs);
              formData.append("syll_phns", syll_phns);
              formData.append("fst", fst);
              console.log("[evaluatePronunciation] ✓ Appended metadata to FormData");
            } else {
              console.warn("[evaluatePronunciation] ✗ Metadata values are empty after conversion");
            }
          } catch (err) {
            console.error("[evaluatePronunciation] ✗ Error converting metadata:", err);
          }
        } else {
          console.warn("[evaluatePronunciation] ✗ Missing metadata - evaluation may fail or be slow");
        }

        // API 호출
        const response = await fetch("/api/speechpro/evaluate", {
          method: "POST",
          body: formData,
          signal: controller.signal,
        });

        // 강건한 에러 처리: 비-JSON/빈 응답 대응
        if (!response.ok) {
          const errorText = await response.text();
          let errorMsg = t("speechpro.msg.eval_failed", "평가 실패");
          try {
            const errJson = errorText ? JSON.parse(errorText) : null;
            if (errJson && (errJson.error || errJson.message)) {
              errorMsg = errJson.error || errJson.message;
            } else if (errorText) {
              errorMsg = errorText;
            }
          } catch (_) {
            if (errorText) errorMsg = errorText;
          }

          if (response.status >= 500) {
            throw new Error(
              `${errorMsg}\n\n${t("speechpro.msg.sentence_too_long", "💡 문장이 너무 길거나 복잡할 수 있습니다. 더 짧은 문장으로 나누어 시도해보세요.")}`
            );
          }
          throw new Error(errorMsg);
        }

        // 정상 응답도 안전하게 파싱
        const okText = await response.text();
        let result;
        try {
          result = okText ? JSON.parse(okText) : null;
        } catch (parseErr) {
          throw new Error(
            t("speechpro.msg.invalid_json", "서버 응답이 JSON이 아닙니다") + 
            `: ${okText?.slice(0, 200) || t("speechpro.msg.empty_response", "빈 응답")}`
          );
        }
        if (!result) {
          throw new Error(t("speechpro.msg.no_valid_response", "서버로부터 유효한 응답을 받지 못했습니다."));
        }

      if (result.success) {
        displayResults(result);
        if (result.score) {
          console.log('[AI Feedback] Calling requestAiFeedback with text:', text, 'score object:', result.score);
          requestAiFeedback(text, result.score);
        } else {
          console.log('[AI Feedback] No score available in result:', result);
        }
      } else {
        showError(result.error || t("speechpro.msg.eval_failed", "평가에 실패했습니다"));
      }
      } catch (error) {
        if (error.name === "AbortError") {
          showError(
            t("speechpro.msg.eval_timeout", "요청이 지연되고 있습니다. 다시 시도해주세요.")
          );
        } else {
          showError(
            `${t("speechpro.msg.eval_error_prefix", "평가 중 오류: ")}${error.message}`
          );
        }
      } finally {
        if (appState.evaluationTimeoutId) {
          clearTimeout(appState.evaluationTimeoutId);
          appState.evaluationTimeoutId = null;
        }
        hideLoading();
      }
    }

    function showAiFeedbackLoading() {
      const modalTarget = document.getElementById("ai-feedback-modal-content");
      if (modalTarget) {
        modalTarget.innerHTML =
          `<div class='text-sm text-blue-700'>${t("speechpro.ai_feedback_loading", "AI 종합 평가를 생성 중입니다...")}</div>`;
      }
      const titleEl = document.getElementById("ai-feedback-step-title");
      if (titleEl) titleEl.textContent = "-";
      aiFeedbackSteps = [];
      aiFeedbackStepIndex = 0;
      updateAiFeedbackStepControls();
    }

    function updateAiFeedbackUI(text, score) {
      console.log('[updateAiFeedbackUI] Called with text:', text?.substring(0, 50), 'score:', score);
      const feedbackContent = document.getElementById("feedback-content");
      const modalContent = document.getElementById("ai-feedback-modal-content");
      const aiTabContent = document.getElementById("result-content-ai");
      console.log('[updateAiFeedbackUI] feedbackContent:', feedbackContent);
      console.log('[updateAiFeedbackUI] modalContent:', modalContent);
      console.log('[updateAiFeedbackUI] aiTabContent:', aiTabContent);
      if (!feedbackContent && !modalContent && !aiTabContent) {
        console.error('[updateAiFeedbackUI] All elements are null, returning');
        return;
      }
      const decorated = formatAiFeedback(text, score);
      const finalText = decorated || text;
      console.log('[updateAiFeedbackUI] finalText length:', finalText?.length);
      latestAiFeedbackText = finalText;
      latestAiFeedbackScore = score || 0;
      const sections = extractFeedbackSections(finalText);
      console.log('[updateAiFeedbackUI] sections:', sections);
      const aiButton = document.getElementById("ai-feedback-button");

      if (sections) {
        console.log('[updateAiFeedbackUI] sections exists, calling buildFeedbackSectionMarkup');
        let markup;
        try {
          markup = buildFeedbackSectionMarkup(sections);
          console.log('[updateAiFeedbackUI] Got markup from buildFeedbackSectionMarkup, length:', markup?.length);
        } catch (error) {
          console.error('[updateAiFeedbackUI] Error in buildFeedbackSectionMarkup:', error);
          throw error;
        }
        
        if (feedbackContent) feedbackContent.innerHTML = markup;
        if (modalContent) {
          console.log('[updateAiFeedbackUI] Setting modalContent.innerHTML with markup');
          modalContent.innerHTML = markup;
        }
        
        try {
          aiFeedbackSteps = buildAiFeedbackStepsFromSections(sections);
          console.log('[updateAiFeedbackUI] Built aiFeedbackSteps, count:', aiFeedbackSteps.length);
        } catch (error) {
          console.error('[updateAiFeedbackUI] Error in buildAiFeedbackStepsFromSections:', error);
          throw error;
        }
      } else {
        const hasEmoji = /[\u{1F300}-\u{1FAFF}\u{2600}-\u{27BF}]/u.test(
          finalText
        );
        if (feedbackContent) {
          renderMarkdownSafe(
            feedbackContent,
            hasEmoji ? finalText : `✨ ${finalText}`
          );
          const blocks = Array.from(feedbackContent.children || []);
          blocks.forEach((el, idx) => {
            if (idx === 0) return;
            el.classList.add("border-t", "border-blue-100", "pt-3", "mt-3");
          });
        }
        if (modalContent) {
          renderMarkdownSafe(
            modalContent,
            hasEmoji ? finalText : `✨ ${finalText}`
          );
          const blocks = Array.from(modalContent.children || []);
          blocks.forEach((el, idx) => {
            if (idx === 0) return;
            el.classList.add("border-t", "border-blue-100", "pt-3", "mt-3");
          });
        }
        aiFeedbackSteps = [
          {
            title: "AI 코멘트",
            markdown: hasEmoji ? finalText : `✨ ${finalText}`,
          },
        ];
      }
      aiFeedbackStepIndex = 0;
      console.log('[updateAiFeedbackUI] About to call renderAiFeedbackStep, steps count:', aiFeedbackSteps.length);
      renderAiFeedbackStep();
      if (aiButton) aiButton.disabled = false;
      
      // AI 탭 업데이트
      if (aiTabContent) {
        console.log('[updateAiFeedbackUI] Updating aiTabContent');
        aiTabContent.innerHTML = `
          <div class="bg-white rounded-2xl p-6">
            <h3 class="text-xl font-bold text-blue-900 mb-4">🤖 AI 종합 피드백</h3>
            <div class="bg-gradient-to-br from-blue-50 via-indigo-50 to-slate-50 border border-blue-100 rounded-2xl p-6">
              <div class="text-blue-900 leading-relaxed whitespace-pre-wrap">${finalText}</div>
            </div>
          </div>
        `;
      }
      
      console.log('[updateAiFeedbackUI] Completed');
    }

    function buildAiFeedbackStepsFromSections(sections) {
      const emptyMessage =
        "<p class='text-sm text-gray-500'>내용이 없습니다.</p>";
      const summaryHtml =
        sections.summary && sections.summary.length
          ? `<p>${sections.summary.join("<br>")}</p>`
          : emptyMessage;
      const strengthsHtml =
        sections.strengths && sections.strengths.length
          ? buildAiFeedbackList(sections.strengths)
          : emptyMessage;
      const improvementsHtml =
        sections.improvements && sections.improvements.length
          ? buildAiFeedbackList(sections.improvements)
          : emptyMessage;
      const tipsHtml =
        sections.tips && sections.tips.length
          ? buildAiFeedbackList(sections.tips)
          : emptyMessage;
      const detailsHtml = getStoredSectionHtml(
        "details-content",
        "상세 분석 데이터가 없습니다."
      );
      const speechproHtml = getStoredSectionHtml(
        "speechpro-content",
        "SpeechPro 분석 데이터가 없습니다."
      );
      const generalHtml =
        sections.general && sections.general.length
          ? buildAiFeedbackList(sections.general)
          : emptyMessage;

      return [
        { title: "핵심 요약", html: summaryHtml },
        { title: "강점 포인트", html: strengthsHtml },
        { title: "개선이 필요한 부분", html: improvementsHtml },
        { title: "연습 팁", html: tipsHtml },
        { title: "상세 분석", html: detailsHtml },
      ];
    }

    function buildAiFeedbackList(items) {
      const listItems = items
        .map(
          (item) =>
            `<li class="flex items-start gap-3 text-gray-800">
              <span class="text-base leading-6 text-gray-500">•</span>
              <span>${item}</span>
            </li>`
        )
        .join("");
      return `<ul class="space-y-2">${listItems}</ul>`;
    }

    function getStoredSectionHtml(id, fallbackText) {
      const target = document.getElementById(id);
      if (!target) {
        return `<p class='text-sm text-gray-500'>${fallbackText}</p>`;
      }
      const html = (target.innerHTML || "").trim();
      if (html) return html;
      return `<p class='text-sm text-gray-500'>${fallbackText}</p>`;
    }

    function renderAiFeedbackStep() {
      console.log('[renderAiFeedbackStep] Called, stepIndex:', aiFeedbackStepIndex, 'steps length:', aiFeedbackSteps.length);
      const titleEl = document.getElementById("ai-feedback-step-title");
      const contentEl = document.getElementById("ai-feedback-modal-content");
      console.log('[renderAiFeedbackStep] contentEl:', contentEl);
      if (!contentEl) {
        console.error('[renderAiFeedbackStep] contentEl is null, returning');
        return;
      }
      if (!aiFeedbackSteps.length) {
        console.log('[renderAiFeedbackStep] No steps, calling showAiFeedbackLoading');
        showAiFeedbackLoading();
        return;
      }
      const step = aiFeedbackSteps[aiFeedbackStepIndex];
      console.log('[renderAiFeedbackStep] Current step:', step);
      if (titleEl) titleEl.textContent = step.title || "-";
      if (step.html) {
        console.log('[renderAiFeedbackStep] Setting innerHTML from step.html');
        contentEl.innerHTML = step.html;
      } else if (step.markdown) {
        console.log('[renderAiFeedbackStep] Rendering markdown:', step.markdown?.substring(0, 50));
        renderMarkdownSafe(contentEl, step.markdown);
      }
      updateAiFeedbackStepControls();
      console.log('[renderAiFeedbackStep] Completed');
    }

    function updateAiFeedbackStepControls() {
      const prevBtn = document.getElementById("ai-feedback-prev");
      const nextBtn = document.getElementById("ai-feedback-next");
      const indicator = document.getElementById("ai-feedback-step-indicator");
      const total = aiFeedbackSteps.length;
      if (indicator) indicator.textContent = `${total ? aiFeedbackStepIndex + 1 : 0} / ${total}`;
      if (prevBtn) prevBtn.disabled = aiFeedbackStepIndex <= 0;
      if (nextBtn) {
        const isLastStep = aiFeedbackStepIndex >= total - 1 && total > 0;
        if (isLastStep) {
          nextBtn.disabled = false;
          nextBtn.textContent = "닫기";
          nextBtn.onclick = closeAiFeedbackModal;
        } else {
          nextBtn.disabled = total === 0;
          nextBtn.textContent = "다음";
          nextBtn.onclick = nextAiFeedbackStep;
        }
      }
    }

    function nextAiFeedbackStep() {
      if (aiFeedbackStepIndex < aiFeedbackSteps.length - 1) {
        aiFeedbackStepIndex += 1;
        renderAiFeedbackStep();
      }
    }

    function prevAiFeedbackStep() {
      if (aiFeedbackStepIndex > 0) {
        aiFeedbackStepIndex -= 1;
        renderAiFeedbackStep();
      }
    }

    async function requestAiFeedback(text, score) {
      if (!text || !score) {
        console.log('[AI Feedback] Missing text or score:', { text, score });
        return;
      }
      
      console.log('[AI Feedback] Starting request with:', { text, score });
      showAiFeedbackLoading();
      
      try {
        // API expects score as a dict with {score, details, error_code}
        const scoreDict = typeof score === 'object' ? score : { score: score, details: {}, error_code: 0 };
        console.log('[AI Feedback] Sending to API:', { text, score: scoreDict });
        
        const response = await fetch("/api/speechpro/feedback", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ text, score: scoreDict }),
        });
        
        console.log('[AI Feedback] Response status:', response.status);
        const data = await response.json();
        console.log('[AI Feedback] Response data:', data);
        console.log('[AI Feedback] data.success:', data.success);
        console.log('[AI Feedback] data.ai_feedback:', data.ai_feedback);
        console.log('[AI Feedback] ai_feedback type:', typeof data.ai_feedback);
        console.log('[AI Feedback] ai_feedback length:', data.ai_feedback?.length);
        
        if (!response.ok || !data.success) {
          console.error('[AI Feedback] Failed - response.ok:', response.ok, 'data.success:', data.success);
          throw new Error(data.error || "AI 종합 평가 실패");
        }
        
        const aiFeedbackText = (data.ai_feedback || "").trim();
        const scoreNum = typeof score === 'object' ? (score.score || 0) : score;
        console.log('[AI Feedback] aiFeedbackText after trim:', aiFeedbackText);
        console.log('[AI Feedback] scoreNum:', scoreNum);
        
        if (aiFeedbackText) {
          console.log('[AI Feedback] Calling updateAiFeedbackUI with text length:', aiFeedbackText.length);
          updateAiFeedbackUI(aiFeedbackText, Math.round(scoreNum));
        } else {
          console.log('[AI Feedback] No feedback text, showing default message');
          updateAiFeedbackUI(
            "AI 피드백을 생성하지 못했습니다.",
            Math.round(scoreNum)
          );
        }
      } catch (err) {
        console.error("[AI Feedback] Error:", err);
        const scoreNum = typeof score === 'object' ? (score.score || 0) : score;
        updateAiFeedbackUI(
          "AI 종합 평가를 불러오지 못했습니다. 잠시 후 다시 시도해주세요.",
          Math.round(scoreNum)
        );
      }
    }

    // 결과 표시
    function displayResults(result) {
      const score = Math.round(result.overall_score || 0);
      const details = result.details || {};

      // 디버깅: 전체 응답 구조 확인
      console.log("=== API Response Structure ===");
      console.log("Full result:", result);
      console.log("Details:", details);
      console.log("Score details:", result.score);
      console.log("Fluency:", details.fluency);
      console.log("Quality:", details.quality);

      // 테스트한 문장 표시
      const testedSentence =
        appState.selectedSentence?.sentenceKr || appState.selectedSentence?.korean || "";
      const feedbackSentenceEl = document.getElementById("feedback-tested-sentence");
      if (feedbackSentenceEl) {
        feedbackSentenceEl.textContent = testedSentence;
      }

      // 점수 업데이트
      document.getElementById("overall-score").textContent = score;

      // 피드백 메시지
      let feedback = "";
      if (score >= 90) feedback = "완벽한 발음입니다! 🌟";
      else if (score >= 80) feedback = "매우 좋은 발음입니다! 👍";
      else if (score >= 70)
        feedback = "좋은 발음입니다. 조금 더 연습하면 더 좋아질 거예요 💪";
      else if (score >= 60)
        feedback = "더 연습이 필요합니다. 계속해서 노력해보세요 📚";
      else feedback = "많은 연습이 필요합니다. 천천히 따라해보세요 🎯";

      document.getElementById("score-feedback").textContent = feedback;

      // 점수 바 업데이트
      document.getElementById("score-bar").style.width = score + "%";

      // Log pronunciation evaluation activity
      const nickname = localStorage.getItem("user_nickname");
      if (nickname && typeof logUserActivity === "function") {
        logUserActivity(nickname, "PRONUNCIATION_EVAL", "/speechpro-practice", {
          score: score,
          text: document
            .getElementById("evaluation-text")
            .value.trim()
            .substring(0, 50),
          scoreRange: score >= 80 ? "high" : score >= 60 ? "medium" : "low",
        });
      }

      // Send mail notification for high scores (80+)
      if (score >= 80 && typeof onScoreAchieved === "function") {
        onScoreAchieved(score);
      } else if (score >= 80) {
        // Fallback: directly add mail if onScoreAchieved not available
        if (typeof addMailNotification === "function") {
          addMailNotification(
            "🏆 높은 점수 달성!",
            `${score}점을 달성하셨습니다! 정말 훌륭합니다! 이 기세를 이어가세요!`,
            "🌟"
          );
        }
      }

      // Store word score history if this is a single-word evaluation
      const token = localStorage.getItem("auth_token");
      const candidate =
        appState.selectedSentence?.sentenceKr || appState.selectedSentence?.korean || testedSentence;
      if (token && candidate && !/\s/.test(candidate)) {
        fetch("/api/learning/word-scores", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`,
          },
          body: JSON.stringify({ word_text: candidate, score }),
        }).catch(() => {});
      }

      // 상세 정보 표시
      let detailsHtml = "";
      if (result.score && result.score.details) {
        const details = result.score.details;

        // 유창성 섹션 제거 (사용자 요청)

        // quality 정보 - 문장별 점수
        if (details.quality && details.quality.sentences) {
          const sentences = details.quality.sentences.filter(
            (s) => s.text !== "!SIL"
          );
          if (sentences.length > 0) {
            detailsHtml += `
            <div class="mb-4">
              <h4 class="font-semibold text-gray-700 mb-2">📝 문장별 평가</h4>
              <div class="space-y-2">
          `;

            sentences.forEach((sent) => {
              const sentScore = Math.round(sent.score || 0);
              const barColor =
                sentScore >= 80
                  ? "bg-green-500"
                  : sentScore >= 60
                  ? "bg-yellow-500"
                  : "bg-red-500";
              detailsHtml += `
              <div class="text-sm">
                <div class="flex justify-between items-center mb-1">
                  <span class="font-medium">${sent.text || "(문장)"}</span>
                  <span class="text-gray-600">${sentScore}점</span>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-2">
                  <div class="${barColor} h-2 rounded-full" style="width: ${sentScore}%"></div>
                </div>
              </div>
            `;
            });

            detailsHtml += `
              </div>
            </div>
          `;
          }
        }

        // 단어별 분석 (모든 문장의 단어들)
        if (details.quality && details.quality.sentences) {
          const allWords = [];
          const allSyllables = [];
          
          details.quality.sentences.forEach((sent) => {
            if (sent.text !== "!SIL" && sent.words && sent.words.length > 0) {
              sent.words.forEach((word) => {
                if (word.text && word.text !== "!SIL") {
                  allWords.push(word);
                  // 음절 데이터도 별도로 수집
                  if (word.syll && word.syll.length > 0) {
                    word.syll.forEach((syll) => {
                      allSyllables.push({
                        word: word.text,
                        syll: syll
                      });
                    });
                  }
                }
              });
            }
          });

          // 2. 단어별 분석 & 3. 음절별 분석을 2열 그리드로 배치
          if (allWords.length > 0 || allSyllables.length > 0) {
            detailsHtml += `
            <div class="mb-4">
              <div class="grid md:grid-cols-2 gap-4">
          `;

            // 왼쪽: 단어별 분석
            if (allWords.length > 0) {
              detailsHtml += `
                <div class="bg-white rounded-lg border border-gray-200 p-4">
                  <h4 class="font-semibold text-gray-700 mb-3 flex items-center gap-2">
                    <span>🔍</span>
                    <span>단어별 분석</span>
                  </h4>
                  <div class="space-y-2 max-h-96 overflow-y-auto">
              `;

              allWords.forEach((word) => {
                const wordScore = Math.round(word.score || 0);
                const scoreColor =
                  wordScore >= 90
                    ? "text-green-600"
                    : wordScore >= 70
                    ? "text-yellow-600"
                    : "text-red-600";
                const barColor =
                  wordScore >= 90
                    ? "bg-green-500"
                    : wordScore >= 70
                    ? "bg-yellow-500"
                    : "bg-red-500";

                detailsHtml += `
                <div class="border-l-4 ${barColor.replace(
                  "bg-",
                  "border-"
                )} pl-3 py-2 bg-gray-50 rounded">
                  <div class="flex justify-between items-center">
                    <span class="font-bold text-base">${word.text || ""}</span>
                    <span class="${scoreColor} font-semibold text-sm">${wordScore}점</span>
                  </div>
                </div>
                `;
              });

              detailsHtml += `
                  </div>
                </div>
              `;
            }

            // 오른쪽: 음절별 분석
            if (allSyllables.length > 0) {
              detailsHtml += `
                <div class="bg-white rounded-lg border border-gray-200 p-4">
                  <h4 class="font-semibold text-gray-700 mb-3 flex items-center gap-2">
                    <span>📊</span>
                    <span>음절별 분석</span>
                  </h4>
                  <div class="space-y-2 max-h-96 overflow-y-auto">
              `;

            allSyllables.forEach((item) => {
              const syll = item.syll;
              const syllScore = Math.round(syll.score || 0);
              const syllColor =
                syllScore >= 90
                  ? "text-green-600"
                  : syllScore >= 70
                  ? "text-yellow-600"
                  : "text-red-600";
              const barColor =
                syllScore >= 90
                  ? "bg-green-500"
                  : syllScore >= 70
                  ? "bg-yellow-500"
                  : "bg-red-500";

              detailsHtml += `
              <div class="border-l-4 ${barColor.replace(
                "bg-",
                "border-"
              )} pl-3 py-2 bg-gray-50 rounded">
                <div class="flex justify-between items-center mb-1">
                  <div>
                    <span class="text-xs text-gray-500">${item.word}</span>
                    <span class="text-gray-400 mx-1">›</span>
                    <span class="font-bold text-base text-gray-900">${syll.text || ""}</span>
                  </div>
                  <span class="${syllColor} font-semibold text-sm">${syllScore}점</span>
                </div>
              `;

              // 음소별 분석
              if (syll.phones && syll.phones.length > 0) {
                detailsHtml += `<div class="ml-2 mt-1 space-y-1 text-sm">`;

                syll.phones.forEach((phone) => {
                  const phoneScore = Math.round(phone.score || 0);
                  const phoneColor =
                    phoneScore >= 90
                      ? "text-green-600"
                      : phoneScore >= 70
                      ? "text-yellow-600"
                      : "text-red-600";

                  detailsHtml += `
                  <div class="flex items-center justify-between border-l-2 border-gray-300 pl-2 py-1 bg-white rounded">
                    <div class="flex items-center gap-2">
                      <span class="font-mono font-bold text-xs text-gray-700">${
                        phone.symbol || ""
                      }</span>
                      <span class="text-gray-500 text-xs">(${
                        phone.text || ""
                      })</span>
                    </div>
                    <span class="${phoneColor} font-semibold text-xs">${phoneScore}점</span>
                  </div>
                  `;
                });

                detailsHtml += `</div>`;
              }

              detailsHtml += `</div>`;
            });

            detailsHtml += `
                  </div>
                </div>
              `;
            }

            detailsHtml += `
              </div>
            </div>
          `;
          }
        }
      }

      if (!detailsHtml) {
        detailsHtml = "<div>발음 평가가 완료되었습니다.</div>";
      }

      // 상세 분석을 analysis 탭에 표시
      document.getElementById("result-content-analysis").innerHTML = `
        <div class="bg-white rounded-2xl p-6">
          <h3 class="text-xl font-bold text-gray-900 mb-4">🎯 SpeechPro 정확도 분석</h3>
          <div id="details-content" class="space-y-3 text-[var(--text-sub)]">${detailsHtml}</div>
          <div
            id="speechpro-content"
            class="mt-6 bg-orange-50 border-l-4 border-orange-400 rounded-lg p-4 space-y-2 text-orange-800"
          ></div>
        </div>
      `;

      // SpeechPro 분석 표시
      let speechproHtml = "";
      const recognizedText =
        (result && (result.recognized_text || result.user_said)) || "";
      const quality = details.quality || {};

      // SpeechPro 데이터 추출 (여러 형식 지원)
      let speechproData = null;
      if (
        result.score &&
        result.score.details &&
        result.score.details.quality
      ) {
        speechproData = result.score.details.quality;
      } else if (result.speechpro) {
        speechproData = result.speechpro;
      } else if (details.quality) {
        speechproData = details.quality;
      }

      console.log("SpeechPro Data:", speechproData);

      if (recognizedText) {
        speechproHtml += `<div class="text-sm text-gray-700">
          <span class="font-semibold">인식된 텍스트:</span>
          <span class="ml-1">${recognizedText}</span>
        </div>`;
      }

      if (speechproData) {
        speechproHtml += `<div class="text-sm space-y-2">`;

        // 여러 가능한 키 조합 시도
        const accuracyKeys = [
          "accuracy_percentage",
          "overall_accuracy",
          "accuracy",
          "accuracy %",
          "accuracy%",
        ];
        const completenessKeys = [
          "completeness_percentage",
          "completeness",
          "completion",
          "completeness %",
          "completeness%",
        ];

        let accuracy = null;
        for (const key of accuracyKeys) {
          if (speechproData[key] !== undefined && speechproData[key] !== null) {
            accuracy = speechproData[key];
            console.log("Found accuracy with key:", key, "value:", accuracy);
            break;
          }
        }

        let completeness = null;
        for (const key of completenessKeys) {
          if (speechproData[key] !== undefined && speechproData[key] !== null) {
            completeness = speechproData[key];
            console.log(
              "Found completeness with key:",
              key,
              "value:",
              completeness
            );
            break;
          }
        }

        // 모든 객체 키를 출력 (디버깅용)
        console.log("All SpeechPro keys:", Object.keys(speechproData));
        for (const [key, value] of Object.entries(speechproData)) {
          if (typeof value === "number") {
            console.log(`  ${key}: ${value}`);
          }
        }

        // sentences 배열에서 정보 추출
        if (
          !accuracy &&
          speechproData.sentences &&
          speechproData.sentences.length > 0
        ) {
          const firstSentence = speechproData.sentences[0];
          if (firstSentence.score !== undefined) {
            accuracy = firstSentence.score;
            console.log("Found accuracy from sentences:", accuracy);
          }
        }

        if (accuracy !== null && accuracy !== undefined) {
          speechproHtml += `<div>✓ 정확도: <strong>${
            typeof accuracy === "number" ? accuracy.toFixed(1) : accuracy
          }%</strong></div>`;
        }
        if (completeness !== null && completeness !== undefined) {
          speechproHtml += `<div>✓ 완성도: <strong>${
            typeof completeness === "number"
              ? completeness.toFixed(1)
              : completeness
          }%</strong></div>`;
        }

        // 데이터가 하나도 없으면 경고
        if (
          (accuracy === null || accuracy === undefined) &&
          (completeness === null || completeness === undefined)
        ) {
          speechproHtml += `<div class="text-gray-600">상세 데이터 처리 중...</div>`;
        }

        speechproHtml += `</div>`;
      } else {
        speechproHtml =
          "<div class='text-sm text-gray-600'>SpeechPro 데이터 준비 중입니다...</div>";
      }
      document.getElementById("speechpro-content").innerHTML = speechproHtml;

      // FluencyPro UI 제거됨: 안전 가드만 두고 바로 스킵
      const fluencyContainer = document.getElementById("fluencypro-content");
      if (fluencyContainer) {
        fluencyContainer.innerHTML = "";
      }

      // AI 피드백 표시
      const rawAiFeedback =
        (result &&
          (result.ai_feedback || result.feedback || result.feedback_text)) ||
        "";

      if (typeof rawAiFeedback === "string" && rawAiFeedback.trim()) {
        updateAiFeedbackUI(rawAiFeedback.trim(), score);
        // AI 탭에도 표시
        document.getElementById("result-content-ai").innerHTML = `
          <div class="bg-white rounded-2xl p-6">
            <h3 class="text-xl font-bold text-blue-900 mb-4">🤖 AI 종합 피드백</h3>
            <div class="bg-gradient-to-br from-blue-50 via-indigo-50 to-slate-50 border border-blue-100 rounded-2xl p-6">
              <div class="text-blue-900 leading-relaxed">${rawAiFeedback}</div>
            </div>
          </div>
        `;
      } else {
        showAiFeedbackLoading();
        document.getElementById("result-content-ai").innerHTML = `
          <div class="bg-white rounded-2xl p-6">
            <h3 class="text-xl font-bold text-blue-900 mb-4">🤖 AI 종합 피드백</h3>
            <div class="text-center py-8 text-gray-500">AI 피드백을 생성 중입니다...</div>
          </div>
        `;
      }

      // 학습 진도 기록 및 Pop-Up 표시
      recordLearningProgress(score);

      // 결과 모달 표시
      document.getElementById("results-modal").classList.remove("hidden");
      
      // 항상 score 탭부터 시작
      switchResultTab('score');
      
      // 폭죽 효과 실행
      launchConfetti(score);
    }

    // 폭죽 효과 함수
    function launchConfetti(score) {
      const canvas = document.getElementById("confetti-canvas");
      if (!canvas) return;
      
      const ctx = canvas.getContext("2d");
      const parent = canvas.parentElement;
      canvas.width = parent.offsetWidth;
      canvas.height = parent.offsetHeight;
      
      const particles = [];
      const particleCount = score >= 80 ? 100 : score >= 60 ? 60 : 40;
      const colors = ['#FF6B6B', '#4ECDC4', '#45B7D1', '#FFA07A', '#98D8C8', '#FFD93D', '#6BCF7F'];
      
      // 파티클 생성
      for (let i = 0; i < particleCount; i++) {
        particles.push({
          x: canvas.width / 2,
          y: canvas.height / 2,
          vx: (Math.random() - 0.5) * 10,
          vy: (Math.random() - 0.5) * 10 - 3,
          color: colors[Math.floor(Math.random() * colors.length)],
          size: Math.random() * 4 + 2,
          life: 1,
          decay: Math.random() * 0.015 + 0.01
        });
      }
      
      function animate() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        
        let activeParticles = 0;
        particles.forEach(p => {
          if (p.life <= 0) return;
          
          activeParticles++;
          p.x += p.vx;
          p.y += p.vy;
          p.vy += 0.3; // 중력
          p.life -= p.decay;
          
          ctx.globalAlpha = p.life;
          ctx.fillStyle = p.color;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.fill();
        });
        
        if (activeParticles > 0) {
          requestAnimationFrame(animate);
        } else {
          ctx.clearRect(0, 0, canvas.width, canvas.height);
        }
      }
      
      animate();
    }

    // 평가 초기화
    function resetEvaluation() {
      closeResults();
      closeAiFeedbackModal();

      const selectEl = document.getElementById("evaluation-text");

      // 선택된 문장이 있으면 dropdown 선택을 복원하고 텍스트도 유지
      if (appState.selectedSentence && (appState.selectedSentence.sentenceKr || appState.selectedSentence.korean)) {
        // 1) 인덱스 기반으로 가장 먼저 복원 (정확)
        if (selectEl && appState.selectedSentenceIndex >= 0 && appState.selectedSentenceIndex < selectEl.options.length) {
          selectEl.selectedIndex = appState.selectedSentenceIndex;
          selectEvaluationSentence();
          return;
        }

        // 2) 텍스트 매칭으로 복원 (백업 경로)
        if (selectEl) {
          for (let i = 0; i < selectEl.options.length; i++) {
            try {
              const optSentence = JSON.parse(selectEl.options[i].value);
              if (
                optSentence?.sentenceKr === appState.selectedSentence.sentenceKr ||
                optSentence?.korean === appState.selectedSentence.korean
              ) {
                selectEl.selectedIndex = i;
                selectEvaluationSentence();
                return;
              }
            } catch (e) {
              /* ignore parse errors */
            }
          }
        }

      } else {
        // 선택된 문장이 없을 때만 기본값으로 리셋
        document.getElementById("evaluation-text").value = "안녕하세요";
        appState.selectedSentence = null;
        if (selectEl) {
          selectEl.selectedIndex = -1;
        }
        document.getElementById("sentence-info-section").classList.add("hidden");
        document.getElementById("sentence-level").textContent = "";
        document.getElementById("sentence-difficulty").textContent = "";
        document.getElementById("sentence-category").textContent = "";
        document.getElementById("sentence-en").textContent = "";
        document.getElementById("sentence-tips").textContent = "";
      }

      const aiButton = document.getElementById("ai-feedback-button");
      if (aiButton) aiButton.disabled = true;

      clearRecording();
    }

    function closeResults() {
      document.getElementById("results-modal").classList.add("hidden");
    }

    function openAiFeedbackModal() {
      document.getElementById("ai-feedback-modal").classList.remove("hidden");
      if (latestAiFeedbackText) {
        renderAiFeedbackStep();
      } else {
        showAiFeedbackLoading();
      }
    }

    function closeAiFeedbackModal() {
      document.getElementById("ai-feedback-modal").classList.add("hidden");
    }

    // 메시지 표시
    function showMessage(message, type = "info") {
      // 간단한 메시지 표시 (토스트 형식으로 개선 가능)
      console.log(`[${type.toUpperCase()}] ${message}`);
    }

    // 에러 표시
    function showError(message) {
      document.getElementById("error-section").classList.remove("hidden");
      document.getElementById("error-message").textContent = message;
    }

    function hideError() {
      document.getElementById("error-section").classList.add("hidden");
    }

    // 로딩 표시
    function showLoading(message) {
      const section = document.getElementById("loading-section");
      if (section) section.classList.remove("hidden");
      const msgEl = document.getElementById("loading-message");
      if (msgEl && typeof message === "string") {
        msgEl.textContent = message;
      }
    }

    function hideLoading() {
      document.getElementById("loading-section").classList.add("hidden");
    }

    // 문장 데이터 로드
    async function loadSentences() {
      const textDiv = document.getElementById("evaluation-text");
      try {
        // 프리셋 메타데이터를 서버에서 로드
        let metadata = null;
        try {
          const formData = new FormData();
          formData.append("text", "내가 그린 기린 그림은 잘 그린 기린 그림이고 네가 그린 기린 그림은 못 그린 기린 그림이다.");
          
          console.log("[loadSentences] Calling /api/speechpro/generate-metadata");
          const metadataResponse = await fetch("/api/speechpro/generate-metadata", {
            method: "POST",
            body: formData
          });
          console.log("[loadSentences] Response status:", metadataResponse.status, metadataResponse.ok);
          
          if (metadataResponse.ok) {
            metadata = await metadataResponse.json();
            console.log("[loadSentences] Metadata response:", metadata);
            if (metadata.success) {
              console.log("[loadSentences] ✓ Generated preset metadata via API");
              console.log("  - syll_ltrs length:", metadata.syll_ltrs?.length || 0);
              console.log("  - syll_phns length:", metadata.syll_phns?.length || 0);
              console.log("  - fst length:", metadata.fst?.length || 0);
            }
          } else {
            const errorData = await metadataResponse.json();
            console.warn("[loadSentences] API error:", errorData);
          }
        } catch (e) {
          console.warn("[loadSentences] Failed to load preset metadata:", e);
        }
        
        // 고정된 텅트위스터 문장
        const sentence = {
          id: 1,
          sentenceKr: "내가 그린 기린 그림은 잘 그린 기린 그림이고 네가 그린 기린 그림은 못 그린 기린 그림이다.",
          sentenceEn: "",
          level: "고급",
          difficulty: "텅트위스터",
          category: "발음연습",
          tags: ["tongue-twister", "발음"],
          tips: "천천히 정확하게 발음하세요.",
          syll_ltrs: metadata?.syll_ltrs || "",
          syll_phns: metadata?.syll_phns || "",
          fst: metadata?.fst || ""
        };

        if (textDiv) {
          // 텍스트 콘텐츠로 표시
          textDiv.textContent = `${sentence.sentenceKr}`;
          
          console.log("[loadSentences] Sentence metadata loaded:");
          console.log("  - has_syll_ltrs:", !!sentence.syll_ltrs);
          console.log("  - has_syll_phns:", !!sentence.syll_phns);
          console.log("  - has_fst:", !!sentence.fst);
          console.log("  - syll_ltrs length:", sentence.syll_ltrs?.length || 0);
          console.log("  - syll_phns length:", sentence.syll_phns?.length || 0);
          console.log("  - fst length:", sentence.fst?.length || 0);
          console.log("  - syll_ltrs preview:", sentence.syll_ltrs?.substring(0, 50));
          console.log("  - syll_phns preview:", sentence.syll_phns?.substring(0, 50));
          console.log("  - fst preview:", sentence.fst?.substring(0, 50));
          
          // 첫 번째 문장을 appState에 저장
          appState.selectedSentence = sentence;
          appState.selectedSentenceIndex = 0;
          selectEvaluationSentence();
        }

        hideError();
      } catch (error) {
        showError(
          `${t("speechpro.msg.sentence_load_error_prefix", "문장 로드 실패: ")}${error.message}`
        );
        if (textDiv) {
          textDiv.textContent = t("speechpro.msg.loading_sentences_failed", "문장 데이터를 불러올 수 없습니다");
        }
      } finally {
        // Cleanup if needed
      }
    }

    // 평가할 문장 선택
    function selectEvaluationSentence() {
      const startButton = document.getElementById("start-recording");

      if (!appState.selectedSentence) {
        // 선택 해제
        appState.selectedSentence = null;
        startButton.disabled = true;
        updateProgressStep(1);
        return;
      }

      try {
        // appState.selectedSentence는 이미 설정됨
        startButton.disabled = false;
        updateProgressStep(2);
        hideError();
      } catch (error) {
        showError(
          t("speechpro.msg.sentence_select_error", "문장 선택 중 오류가 발생했습니다")
        );
        startButton.disabled = true;
        appState.selectedSentenceIndex = -1;
      }
    }
    
    // Progress indicator update
    function updateProgressStep(step) {
      const colors = {
        1: 'bg-orange-700',
        2: 'bg-indigo-700',
        3: 'bg-purple-700'
      };
      
      [1, 2, 3].forEach(i => {
        const stepEl = document.getElementById(`step-${i}`);
        // 각 step의 기본 색상은 유지하고 업데이트하지 않음
      });
    }

    // 다음 문장으로 이동
    function nextSentence() {
      // 현재는 문장이 1개뿐이므로 동작 없음
      return;
    }

    // 문장 TTS 재생
    async function playSelectedSentenceTTS() {
      if (!appState.selectedSentence) {
        showError("문장을 먼저 선택해주세요");
        return;
      }
      
      const text = appState.selectedSentence.sentenceKr || appState.selectedSentence.korean || "";
      if (!text) {
        showError("재생할 문장이 없습니다");
        return;
      }
      
      const btn = document.getElementById('listen-sentence-btn');
      btn.disabled = true;
      btn.textContent = "🔊 재생 중...";
      
      try {
        const response = await fetch('/api/tts/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            text: text,
            speaker: 0,
            tempo: 0.9,
            pitch: 1.0,
            gain: 1.2,
            backend: "edge"
          })
        });
        
        if (!response.ok) {
          throw new Error('TTS 생성 실패');
        }
        
        const audioBlob = await response.blob();
        const audioUrl = URL.createObjectURL(audioBlob);
        const audio = new Audio(audioUrl);
        
        audio.onended = () => {
          URL.revokeObjectURL(audioUrl);
          btn.disabled = false;
          btn.textContent = "🔊 들어보기";
        };
        
        audio.onerror = () => {
          URL.revokeObjectURL(audioUrl);
          btn.disabled = false;
          btn.textContent = "🔊 들어보기";
          showError("음성 재생 중 오류가 발생했습니다");
        };
        
        await audio.play();
      } catch (error) {
        console.error('TTS 재생 오류:', error);
        showError("음성 재생에 실패했습니다");
        btn.disabled = false;
        btn.textContent = "🔊 들어보기";
      }
    }

    // 학습 진도 기록 및 캐릭터 Pop-Up 표시
    async function recordLearningProgress(score) {
      try {
        const nickname = localStorage.getItem("user_nickname");
        console.log("Recording progress for user:", nickname, "score:", score);

        if (!nickname) {
          console.warn("No user nickname found in localStorage");
          return;
        }

        // 1. 학습 진도 기록
        console.log("Calling pronunciation-completed API...");
        const progressResponse = await fetch(
          "/api/learning/pronunciation-completed",
          {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              user_id: nickname,
              score: score,
              timestamp: new Date().toISOString(),
            }),
          }
        );

        console.log("Progress response status:", progressResponse.status);

        if (!progressResponse.ok) {
          const errorText = await progressResponse.text();
          console.error("Failed to record learning progress:", errorText);
          return;
        }

        const progressData = await progressResponse.json();
        console.log("Progress data saved:", progressData);

        // 2. Pop-Up 표시 여부 확인
        console.log("Checking popup trigger...");
        const popupToken = localStorage.getItem("session_token");
        if (!popupToken) {
          console.warn("No session token for popup check.");
          return;
        }

        const popupCheckResponse = await fetch("/api/learning/check-popup", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${popupToken}`,
          },
        });

        console.log("Popup check response status:", popupCheckResponse.status);

        if (!popupCheckResponse.ok) {
          const errorText = await popupCheckResponse.text();
          console.error("Failed to check popup:", errorText);
          return;
        }

        const popupPayload = await popupCheckResponse.json();
        console.log("Popup data:", popupPayload);

        if (popupPayload.popup && popupPayload.popup.should_show) {
          const popup = popupPayload.popup;
          console.log("Showing popup:", popup);
          showCharacterPopup(
            popup.character || "오빠",
            popup.message,
            popup.type || "info"
          );

          await fetch("/api/learning/popup-shown", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Authorization: `Bearer ${popupToken}`,
            },
            body: JSON.stringify({
              popup_type: popup.type,
              character: popup.character,
              message: popup.message,
              trigger_reason: popup.trigger,
            }),
          });
        }
      } catch (error) {
        console.error("Error recording learning progress:", error);
      }
    }

    // 캐릭터별 메시지 스타일 정의
    const CHARACTER_STYLES = {
      오빠: {
        emoji: "🧑",
        color: "bg-blue-100",
        sealColor: "bg-blue-500",
        borderColor: "border-blue-900",
        role: "현재 상황 안내",
      },
      호랑이: {
        emoji: "🐯",
        color: "bg-orange-100",
        sealColor: "bg-orange-500",
        borderColor: "border-orange-900",
        role: "경고와 독려",
      },
      동생: {
        emoji: "👧",
        color: "bg-pink-100",
        sealColor: "bg-pink-500",
        borderColor: "border-pink-900",
        role: "칭찬",
      },
    };

    // 캐릭터 Pop-Up 표시 함수
    function showCharacterPopup(character, message, popupType = "info") {
      const style = CHARACTER_STYLES[character] || CHARACTER_STYLES["오빠"];

      // Pop-Up 요소 업데이트
      const modal = document.getElementById("character-popup-modal");
      const letter = document.getElementById("popup-letter");
      const charDiv = document.getElementById("popup-character");
      const senderDiv = document.getElementById("popup-sender");
      const messageDiv = document.getElementById("popup-message");
      const sealDiv = document.getElementById("popup-seal");
      const dateDiv = document.getElementById("popup-date");

      if (modal && letter && charDiv && senderDiv && messageDiv && sealDiv) {
        // 색상 및 스타일 업데이트
        letter.className = `bg-yellow-50 rounded-none border-8 ${style.borderColor} p-8 shadow-2xl relative`;
        sealDiv.className = `absolute -top-4 -right-4 w-16 h-16 rounded-full shadow-lg flex items-center justify-center text-3xl font-bold ${style.sealColor} text-white`;

        // 캐릭터 및 메시지 업데이트
        charDiv.textContent = style.emoji;
        senderDiv.textContent = `${character}로부터`;
        messageDiv.textContent = message;

        if (dateDiv) {
          const today = new Date().toLocaleDateString("ko-KR");
          dateDiv.textContent = today;
        }

        // 모달 표시
        modal.classList.remove("hidden");
        modal.addEventListener("click", closeCharacterPopup);
      }
    }

    // Pop-Up 닫기
    function closeCharacterPopup(event) {
      if (event && event.target.id !== "character-popup-modal") return;
      const modal = document.getElementById("character-popup-modal");
      if (modal) {
        modal.classList.add("hidden");
      }
    }

    // 초기화
    document.addEventListener("DOMContentLoaded", () => {
      // 문장 데이터 로드
      loadSentences();

      // SpeechPro 장점 모달 이벤트 바인딩
      const openAdvBtn = document.getElementById("open-speechpro-advantages");
      const advModal = document.getElementById("speechpro-advantages-modal");
      const advClose = document.getElementById("speechpro-advantages-close");
      const advOverlay = document.getElementById(
        "speechpro-advantages-overlay"
      );

      const openAdvModal = () => {
        if (advModal) advModal.classList.remove("hidden");
        document.body.classList.add("overflow-hidden");
      };

      const closeAdvModal = () => {
        if (advModal) advModal.classList.add("hidden");
        document.body.classList.remove("overflow-hidden");
      };

      if (openAdvBtn) openAdvBtn.addEventListener("click", openAdvModal);
      if (advClose) advClose.addEventListener("click", closeAdvModal);
      if (advOverlay)
        advOverlay.addEventListener("click", (e) => {
          if (e.target === advOverlay) closeAdvModal();
        });

      // 첫 방문 환영 팝업 (페이지별로 한 번씩 노출)
      try {
        const nickname = localStorage.getItem("user_nickname") || "새 학습자";
        const pageFlagKey = `welcome_popup_shown_${nickname}_speechpro`;
        const alreadyShown = localStorage.getItem(pageFlagKey) === "true";
        if (!alreadyShown) {
          showCharacterPopup(
            "오빠",
            "오누이 한국어 학습 플랫폼에 오신 것을 환영합니다! AI와 함께 발음·유창성 연습을 바로 시작해보세요.",
            "info"
          );
          localStorage.setItem(pageFlagKey, "true");
        }
      } catch (err) {
        console.warn("Failed to show welcome popup:", err);
      }

      // Pop-Up 닫기 버튼 이벤트
      const modal = document.getElementById("character-popup-modal");
      if (modal) {
        modal.addEventListener("click", function (e) {
          if (e.target === modal) {
            closeCharacterPopup();
          }
        });
      }
    });
  </script>

  <!-- 캐릭터 팝업 모달 -->
  <div
    id="character-popup-modal"
    class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center backdrop-blur-sm"
  >
    <div
      class="bg-white rounded-3xl shadow-2xl p-8 max-w-lg w-full mx-4 relative animate-bounce-in"
      id="character-modal-box"
    >
      <button
        id="close-character-popup"
        class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 text-2xl"
      >
        ×
      </button>

      <div class="text-center mb-6">
        <h2 class="text-3xl font-bold text-gray-900 mb-2">
          <span class="inline-block mr-2">💌</span>편지가 도착했어요!
        </h2>
      </div>

      <div class="flex gap-4">
        <!-- Character Avatar -->
        <div class="flex flex-col items-center flex-shrink-0">
          <div
            id="popup-character"
            class="w-24 h-24 rounded-full flex items-center justify-center text-5xl font-bold border-4 flex-shrink-0"
          >
            🧑
          </div>
          <p id="popup-sender" class="mt-2 text-sm font-semibold text-gray-600">
            오빠
          </p>
        </div>

        <!-- Message -->
        <div class="flex-1">
          <div class="bg-gray-50 rounded-2xl p-4 rounded-tl-none">
            <p
              id="popup-message"
              class="text-gray-800 text-base leading-relaxed"
            >
              메시지
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    @keyframes bounce-in {
      0% {
        transform: scale(0.7);
        opacity: 0;
      }
      100% {
        transform: scale(1);
        opacity: 1;
      }
    }
    .animate-bounce-in {
      animation: bounce-in 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    
    /* Recording Status Visualizer Styles */
    @keyframes pulse {
      0%, 100% {
        opacity: 1;
      }
      50% {
        opacity: 0.5;
      }
    }
    
    [data-status="idle"] #status-dot {
      background-color: #9CA3AF; /* gray-400 */
    }
    
    [data-status="recording"] #status-dot {
      background-color: #EF4444; /* red-500 */
      animation: pulse 1s ease-in-out infinite;
    }
    
    [data-status="recorded"] #status-dot {
      background-color: #10B981; /* green-500 */
    }
    
    @keyframes wave {
      0%, 100% {
        height: 8px;
      }
      50% {
        height: 32px;
      }
    }
    
    .waveform-bar {
      animation: wave 0.8s ease-in-out infinite;
    }
    
    /* Result Modal Step Transition */
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    
    .result-step {
      animation: fadeIn 0.3s ease-out;
    }
    
    .result-step.hidden {
      display: none;
    }
  </style>

  {% endblock %}
</div>
