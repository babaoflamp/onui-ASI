{% extends "base.html" %} {% block title %}AI 발음 종합 평가 테스트 - 오누이 AI{% endblock
%} {% block content %}
<div id="alertsContainer"></div>
<div class="max-w-4xl mx-auto px-4 py-8">
  <!-- Header -->
  <div class="mb-8 relative">
    <!-- Help Button (moved from below) -->
    <button
      id="open-speechpro-advantages"
      type="button"
      class="absolute top-0 right-0 p-2 hover:bg-gray-100 rounded-full transition-colors"
      title="SpeechPro 장점 보기"
    >
      <span class="text-2xl">ℹ️</span>
    </button>
    
    <div
      class="inline-flex items-center gap-2 px-3 py-1 bg-orange-100 text-orange-800 rounded-full text-xs font-semibold mb-2"
    >
      <span class="w-2 h-2 bg-orange-500 rounded-full"></span>
      <span data-i18n="speechpro.badge">ONUI · AI 학습 도구</span>
    </div>
    <h1 class="text-3xl font-bold text-gray-900 mb-2">
      <span class="text-2xl">🎤</span>
      <span data-i18n="speechpro.title">AI로 발음 평가 받기</span>
    </h1>
    <p class="text-sm text-gray-600" data-i18n="speechpro.subtitle">
      한국어 발음의 정확도를 평가받고 개별 음소별 피드백을 얻어보세요
    </p>
  </div>

  <!-- 콘텐츠 영역 -->
  <div class="bg-white rounded-2xl p-6 shadow-lg">
      <!-- Progress Steps -->
      <div class="mb-4">
        <div class="flex items-center justify-between max-w-2xl mx-auto">
          <div class="flex flex-col items-center flex-1">
            <div class="step-number w-12 h-12 rounded-full bg-orange-400 text-white flex items-center justify-center font-bold text-lg mb-3 cursor-pointer" id="step-1">1</div>
            <span class="text-sm font-semibold text-gray-700">문장 선택</span>
          </div>
          <div class="flex-1 flex items-center justify-center" id="step-line-1">
            <span class="step-arrow">›</span>
          </div>
          <div class="flex flex-col items-center flex-1">
            <div class="step-number w-12 h-12 rounded-full bg-cyan-400 text-white flex items-center justify-center font-bold text-lg mb-3 cursor-pointer" id="step-2">2</div>
            <span class="text-sm font-semibold text-gray-700">녹음</span>
          </div>
          <div class="flex-1 flex items-center justify-center" id="step-line-2">
            <span class="step-arrow">›</span>
          </div>
          <div class="flex flex-col items-center flex-1">
            <div class="step-number w-12 h-12 rounded-full bg-purple-400 text-white flex items-center justify-center font-bold text-lg mb-3 cursor-pointer" id="step-3">3</div>
            <span class="text-sm font-semibold text-gray-700">평가</span>
          </div>
        </div>
      </div>
      
      <!-- SpeechPro 장점 모달 -->
      <div
        id="speechpro-advantages-modal"
        class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
        aria-modal="true"
        role="dialog"
      >
        <div id="speechpro-advantages-overlay" class="absolute inset-0"></div>
        <div
          class="relative bg-white rounded-2xl shadow-2xl max-w-3xl w-full p-6 md:p-8 overflow-y-auto max-h-[90vh]"
        >
          <button
            id="speechpro-advantages-close"
            type="button"
            class="absolute top-4 right-4 text-gray-500 hover:text-gray-700 text-2xl"
            aria-label="닫기"
          >
            ×
          </button>

            <h3 class="text-2xl font-bold text-blue-900 mb-4" data-i18n="speechpro.modal_title">
              🎤 SpeechPro 발음 정확도 평가의 장점
            </h3>

          <div class="space-y-4">
            <div class="rounded-xl border border-blue-100 bg-blue-50/60 p-4">
              <p class="text-sm font-semibold text-blue-900" data-i18n="speechpro.modal_overview_title">한눈에 비교</p>
              <p class="text-xs text-blue-800 mt-1" data-i18n="speechpro.modal_overview_desc">
                SpeechPro는 발음 모델 기반의 정밀 분석과 AI 종합 피드백을 제공합니다.
              </p>
            </div>

            <div class="overflow-hidden rounded-xl border border-gray-200">
              <table class="w-full text-sm">
                <thead class="bg-gray-50 text-gray-700">
                  <tr>
                    <th class="px-4 py-3 text-left w-1/3" data-i18n="speechpro.table.header">구분</th>
                    <th class="px-4 py-3 text-left" data-i18n="speechpro.table.general">일반 평가</th>
                    <th class="px-4 py-3 text-left text-blue-900" data-i18n="speechpro.table.speechpro">SpeechPro</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                  <tr>
                    <td class="px-4 py-3 font-semibold text-gray-800" data-i18n="speechpro.table.row1.label">분석 단위</td>
                    <td class="px-4 py-3 text-gray-600" data-i18n="speechpro.table.row1.general">문장 전체 중심</td>
                    <td class="px-4 py-3 text-gray-800" data-i18n="speechpro.table.row1.pro">음소/발음 단위 정밀 분석</td>
                  </tr>
                  <tr>
                    <td class="px-4 py-3 font-semibold text-gray-800" data-i18n="speechpro.table.row2.label">정확도</td>
                    <td class="px-4 py-3 text-gray-600" data-i18n="speechpro.table.row2.general">대략적 점수</td>
                    <td class="px-4 py-3 text-gray-800" data-i18n="speechpro.table.row2.pro">FST 발음 모델 기반 정밀 평가</td>
                  </tr>
                  <tr>
                    <td class="px-4 py-3 font-semibold text-gray-800" data-i18n="speechpro.table.row3.label">피드백</td>
                    <td class="px-4 py-3 text-gray-600" data-i18n="speechpro.table.row3.general">요약 안내</td>
                    <td class="px-4 py-3 text-gray-800" data-i18n="speechpro.table.row3.pro">AI 종합 피드백 + 개선 전략</td>
                  </tr>
                  <tr>
                    <td class="px-4 py-3 font-semibold text-gray-800" data-i18n="speechpro.table.row4.label">학습 활용</td>
                    <td class="px-4 py-3 text-gray-600" data-i18n="speechpro.table.row4.general">반복 연습 위주</td>
                    <td class="px-4 py-3 text-gray-800" data-i18n="speechpro.table.row4.pro">강점/개선 포인트 기반 집중 학습</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
              <div class="rounded-lg border border-gray-100 bg-white p-4">
                <p class="text-xs text-gray-500" data-i18n="speechpro.modal_strength_label">핵심 강점</p>
                <p class="text-sm font-semibold text-gray-900 mt-1">
                  <span data-i18n="speechpro.modal_strength_title">음소별 정확도 시각화</span>
                </p>
                <p class="text-xs text-gray-600 mt-1" data-i18n="speechpro.modal_strength_desc">
                  어떤 발음이 틀렸는지 바로 확인
                </p>
              </div>
              <div class="rounded-lg border border-gray-100 bg-white p-4">
                <p class="text-xs text-gray-500" data-i18n="speechpro.modal_ai_label">AI 종합 피드백</p>
                <p class="text-sm font-semibold text-gray-900 mt-1">
                  <span data-i18n="speechpro.modal_ai_title">SpeechPro + FluencyPro 통합</span>
                </p>
                <p class="text-xs text-gray-600 mt-1" data-i18n="speechpro.modal_ai_desc">
                  강점/개선/다음 학습 방향 제시
                </p>
              </div>
              <div class="rounded-lg border border-gray-100 bg-white p-4">
                <p class="text-xs text-gray-500" data-i18n="speechpro.modal_eff_label">학습 효율</p>
                <p class="text-sm font-semibold text-gray-900 mt-1">
                  <span data-i18n="speechpro.modal_eff_title">빠른 개선 포인트 집중</span>
                </p>
                <p class="text-xs text-gray-600 mt-1" data-i18n="speechpro.modal_eff_desc">
                  시간 대비 학습 효과를 극대화
                </p>
              </div>
            </div>

            <div class="bg-white p-4 rounded-lg border-t-2 border-blue-200">
              <p class="text-sm text-gray-700" data-i18n-html="speechpro.modal_tip">
                <strong>TIP:</strong> SpeechPro로 음소별 정확도를 확인한 뒤,
                FluencyPro로 자연스러운 발화를 연습하면 효과적입니다.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- 메인 카드 -->
      <div class="bg-white rounded-2xl shadow-lg p-4 mb-2 mt-2">
        <!-- 평가할 문장 선택 섹션 -->
        <div class="mb-3">
          <label
            class="block text-xl font-bold text-[var(--text-main)] mb-2"
            data-i18n="speechpro.select_label"
          >
            📚 평가할 문장
          </label>
          <div class="flex flex-col">
            <div
              id="evaluation-text"
              class="flex-1 px-4 py-3 border-2 border-[var(--accent)] rounded-lg text-lg font-semibold text-[var(--text-main)] bg-gradient-to-r from-orange-50 to-cyan-50 min-h-[60px] flex items-center"
            >
            </div>
            <div class="flex gap-2 sm:w-auto w-full">
              <button
                id="listen-sentence-btn"
                class="px-7 py-3.5 bg-orange-400 text-white rounded-xl font-semibold text-base hover:bg-orange-500 transition active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed flex-1 sm:flex-initial"
              >
                🔊 들어보기
              </button>
              <button
                id="next-sentence-btn"
                class="px-7 py-3.5 bg-cyan-400 text-white rounded-xl font-semibold text-base hover:bg-cyan-500 transition active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed flex-1 sm:flex-initial"
              >
                ➡️ 다음
              </button>
            </div>
          </div>

          <!-- 직접 입력 기능 제거됨 -->
        </div>

        <!-- 레코딩 섹션 -->
        <div class="mb-3">
          <label
            class="block text-xl font-bold text-[var(--text-main)] mb-2"
            data-i18n="speechpro.record_label"
          >
            🎙️ 음성 녹음
          </label>

          <div
            class="border-2 border-dashed border-[var(--accent)] rounded-lg p-4 text-center bg-gray-50"
          >
            <!-- Recording Status Visualizer -->
            <div class="mb-3">
              <div id="recording-visualizer" class="flex flex-col items-center gap-4">
                <!-- Status Badge -->
                <div class="flex items-center gap-3 px-4 py-2 bg-white rounded-full shadow-sm" data-status="idle">
                  <span id="status-dot" class="w-3 h-3 bg-gray-400 rounded-full"></span>
                  <span id="status-text" class="text-sm font-semibold text-gray-700" data-i18n="speechpro.status_idle">대기 중</span>
                </div>
                
                <!-- Waveform Animation (hidden by default) -->
                <div id="waveform" class="hidden flex items-center gap-1 h-12">
                  <span class="waveform-bar w-1 bg-red-500 rounded-full" style="animation-delay: 0s"></span>
                  <span class="waveform-bar w-1 bg-red-500 rounded-full" style="animation-delay: 0.1s"></span>
                  <span class="waveform-bar w-1 bg-red-500 rounded-full" style="animation-delay: 0.2s"></span>
                  <span class="waveform-bar w-1 bg-red-500 rounded-full" style="animation-delay: 0.3s"></span>
                  <span class="waveform-bar w-1 bg-red-500 rounded-full" style="animation-delay: 0.4s"></span>
                </div>
                
                <!-- Timer Display (always visible) -->
                <div id="recording-timer-display" class="text-3xl font-mono font-bold text-gray-700">
                  00:00
                </div>
              </div>
            </div>

            <!-- 카운트다운 표시 -->
            <div
              id="countdown-display"
              class="text-6xl font-bold text-red-500 text-center mb-4 hidden"
            >
              3
            </div>

            <!-- Primary Action Button -->
            <div class="mb-3">
              <button
                id="start-recording"
                class="w-full py-4 bg-rose-400 text-white rounded-xl font-semibold text-lg hover:bg-rose-500 transition active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed"
                disabled
                data-i18n="speechpro.btn_start_record"
              >
                🎙️ 녹음 시작
              </button>
              <button
                id="stop-recording"
                class="w-full py-4 bg-slate-700 text-white rounded-xl font-semibold text-lg hover:bg-slate-800 transition active:scale-95 hidden"
                data-i18n="speechpro.btn_stop_record"
              >
                ⏹️ 녹음 중지
              </button>
            </div>

            <!-- 평가 버튼 -->
            <div class="mt-3">
              <button
                id="evaluate-button"
                class="w-full py-4 bg-indigo-400 text-white rounded-xl font-semibold text-lg hover:bg-indigo-500 transition active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed"
                data-i18n="speechpro.btn_evaluate"
              >
                🪄 AI로 발음 정확도 평가하기
              </button>
            </div>

            <!-- 녹음 시간 표시 (숨김 처리 제거됨 - 위의 visualizer로 통합) -->
            <div
              id="recording-timer"
              class="text-2xl font-mono text-[var(--accent)] mb-4 hidden"
            >
              00:00
            </div>

            <!-- 재생 섹션 -->
            <div id="playback-section" class="mt-6 hidden">
              <p class="text-sm text-gray-600 mb-3" data-i18n="speechpro.playback_label">녹음된 음성:</p>
              <audio
                id="audio-playback"
                controls
                class="w-full mb-3 rounded-lg"
              ></audio>
            </div>
          </div>
        </div>

      <!-- 평가 버튼이 위로 이동됨 -->
    </div>

    <!-- 결과 모달 -->
      <div
        id="results-modal"
        class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 p-4"
        role="dialog"
        aria-modal="true"
        aria-labelledby="results-modal-title"
      >
        <div
          class="relative w-full max-w-4xl lg:max-w-5xl max-h-[90vh] overflow-y-auto bg-white rounded-2xl shadow-2xl p-8"
          role="document"
        >
          <div
            class="sticky top-0 z-10 -mx-8 -mt-8 px-8 pt-2 pb-2 bg-white/95 backdrop-blur border-b border-gray-100"
          >
            <div class="flex items-center justify-between mb-4">
              <h2 
                id="results-modal-title"
                class="text-2xl font-bold text-[var(--text-main)] m-0" 
                data-i18n="speechpro.results_title"
              >
                📊 평가 결과
              </h2>
              <button
                id="close-results-btn"
                class="text-gray-500 hover:text-gray-800 text-2xl"
                aria-label="닫기"
              >
                ✕
              </button>
            </div>
            
            <!-- Result Tabs -->
            <div class="flex gap-2 mt-4 border-b border-gray-200">
              <button
                id="tab-score"
                class="result-tab px-4 py-2 font-semibold border-b-2 border-orange-500 text-orange-600"
                data-tab="score"
              >
                📊 점수
              </button>
              <button
                id="tab-analysis"
                class="result-tab px-4 py-2 font-semibold border-b-2 border-transparent text-gray-500 hover:text-gray-700"
                data-tab="analysis"
              >
                🎯 상세 분석
              </button>
              <button
                id="tab-ai"
                class="result-tab px-4 py-2 font-semibold border-b-2 border-transparent text-gray-500 hover:text-gray-700"
                data-tab="ai"
              >
                🤖 AI 피드백
              </button>
            </div>
      </div>

    <!-- AI 종합 평가 모달 -->
    <div
      id="ai-feedback-modal"
      class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 p-4"
      role="dialog"
      aria-modal="true"
      aria-labelledby="ai-feedback-modal-title"
    >
      <div
        class="relative w-full max-w-3xl max-h-[90vh] overflow-y-auto bg-white rounded-2xl shadow-2xl p-8"
        role="document"
      >
        <div class="flex items-center justify-between mb-4">
          <h2 
            id="ai-feedback-modal-title"
            class="text-2xl font-bold text-[var(--text-main)]" 
            data-i18n="speechpro.ai_modal_title"
          >
            🤖 AI 종합 평가 결과
          </h2>
          <button
            id="close-ai-feedback-modal-btn"
            class="text-gray-500 hover:text-gray-800 text-2xl"
            aria-label="닫기"
          >
            ✕
          </button>
        </div>

        <div class="mb-3 text-xs font-semibold text-blue-600 uppercase tracking-wide">
          AI 코칭 단계
        </div>
        <h3 id="ai-feedback-step-title" class="text-xl font-bold text-blue-900 mb-3">
          -
        </h3>

        <div
          id="ai-feedback-modal-content"
          class="relative text-blue-900 leading-loose text-base bg-white/70 border border-blue-100 rounded-xl p-6 shadow-inner"
          style="line-height: 1.8"
        >
          <div class="text-sm text-blue-700" data-i18n="speechpro.ai_feedback_loading">
            AI 종합 평가를 생성 중입니다...
          </div>
        </div>

        <div class="mt-4 flex items-center justify-between">
          <button
            id="ai-feedback-prev"
            class="px-4 py-2 rounded-lg border border-gray-200 text-gray-700 text-sm font-semibold hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed"
            disabled
          >
            이전
          </button>
          <div id="ai-feedback-step-indicator" class="text-xs text-gray-500">
            0 / 0
          </div>
          <button
            id="ai-feedback-next"
            class="px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-semibold hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed"
            disabled
          >
            다음
          </button>
        </div>

        <div id="ai-feedback-detail-storage" class="hidden">
          <div id="details-content" class="space-y-3 text-[var(--text-sub)]"></div>
          <div
            id="speechpro-content"
            class="bg-orange-50 border-l-4 border-orange-400 rounded-lg p-4 space-y-2 text-orange-800"
          ></div>
        </div>
      </div>
    </div>

          <!-- 점수 카드 -->
          <div id="result-content-score" class="result-step mt-6">
            <div class="bg-white rounded-2xl p-6">
              <!-- 전체 점수 -->
              <div class="mb-6">
                <div class="text-center relative">
                  <!-- 폭죽 캔버스 -->
                  <canvas id="confetti-canvas" class="absolute inset-0 pointer-events-none" style="z-index: 10;"></canvas>
                  
                  <div class="text-8xl font-bold text-[var(--accent)] mb-4 relative z-20">
                    <span id="overall-score">0</span>/100
                  </div>
                  <p
                    id="score-feedback"
                    class="text-2xl text-[var(--text-sub)] font-semibold"
                  ></p>
                </div>

                <!-- 점수 게이지 -->
                <div class="mt-8">
                  <div
                    class="w-full bg-gray-200 rounded-full h-6 overflow-hidden"
                  >
                    <div
                      id="score-bar"
                      class="bg-gradient-to-r from-red-500 via-yellow-500 to-green-500 h-full transition-all duration-500"
                      style="width: 0%"
                    ></div>
                  </div>
                </div>
              </div>
              
              <!-- Next Step Button -->
              <div class="text-center mt-8">
                <button
                  id="view-details-btn"
                  class="px-8 py-3 bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 transition"
                >
                  상세 분석 보기 →
                </button>
              </div>
            </div>
          </div>

          <!-- 상세 분석 탭 (기존 내용) -->
          <div id="result-content-analysis" class="result-step hidden mt-6"></div>

          <!-- AI 피드백 탭 -->
          <div id="result-content-ai" class="result-step hidden mt-6"></div>

          <!-- Bottom buttons -->
          <div class="flex justify-end gap-3 mt-6튼">
            <button
              id="close-results-btn-2"
              class="px-6 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300 transition"
              data-i18n="speechpro.btn_close"
            >
              닫기
            </button>
            <button
              id="reset-evaluation-btn"
              class="px-6 py-2 bg-gray-500 text-white rounded-lg font-semibold hover:opacity-90 transition"
              data-i18n="speechpro.btn_reset"
            >
              🔄 다시 평가하기
            </button>
          </div>
        </div>
      </div>

      <!-- 에러 메시지 -->
      <div
        id="error-section"
        class="hidden bg-red-50 border-l-4 border-red-500 rounded-lg p-6"
      >
        <h3 class="text-lg font-semibold text-red-900 mb-2" data-i18n="speechpro.error_title">❌ 오류</h3>
        <p id="error-message" class="text-red-800"></p>
      </div>

      <!-- 로딩 표시 -->
      <div
        id="loading-section"
        class="hidden fixed inset-0 z-40 flex items-center justify-center bg-white/70 backdrop-blur-sm"
      >
        <div
          class="text-center px-6 py-4 rounded-xl bg-white shadow-lg border border-orange-100"
        >
          <div
            class="mx-auto mb-4 animate-spin rounded-full h-12 w-12 border-4 border-[var(--accent)] border-t-transparent"
            aria-hidden="true"
          ></div>
          <p id="loading-message" class="text-[var(--text-sub)] font-semibold" data-i18n="speechpro.loading">
            처리 중...
          </p>
        </div>
      </div>
    </div>
  </div>

  <script>
    window.PAGE_I18N = {
      ko: {
